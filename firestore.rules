rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entities ---

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && 
                      resource.data.userId == request.auth.uid &&
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'type', 'category', 'amount', 'date', 'userId']) &&
             data.keys().size() <= 7 && // optional description
             data.id is string &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.amount is number &&
             data.date is string &&
             data.userId is string;
    }

    match /goals/{goalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      isValidGoal(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && 
                      resource.data.userId == request.auth.uid &&
                      isValidGoal(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['id', 'name', 'target', 'current', 'userId']) &&
             data.keys().size() <= 6 && // optional color
             data.id is string &&
             data.name is string &&
             data.target is number &&
             data.current is number &&
             data.userId is string;
    }
  }
}
